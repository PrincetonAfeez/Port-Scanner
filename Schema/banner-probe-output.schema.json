{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "portsleuth Banner Probe JSON Output",
  "description": "Array emitted by `portsleuth probe banner ... --format json`.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "target",
      "address",
      "port",
      "banner"
    ],
    "properties": {
      "target": {
        "type": "string"
      },
      "address": {
        "type": "string"
      },
      "port": {
        "$ref": "common-defs.schema.json#/$defs/port"
      },
      "banner": {
        "$ref": "common-defs.schema.json#/$defs/nullableString"
      }
    }
  }
}
